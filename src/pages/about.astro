---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="About — SM Gives"
	description="SM Gives is a 501(c)(3) tax-exempt nonprofit located in Raleigh, NC. 100% of every gift impacts high need populations around the world."
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "AboutPage",
			"name": "About SM Gives",
			"url": "https://smgives.org/about",
			"mainEntity": {
				"@type": "NonprofitOrganization",
				"name": "Spirit Media Charities",
				"alternateName": "SM Gives",
				"description": "501(c)(3) tax-exempt organization empowering people to serve and sharing life giving resources.",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "8045 Arco Corporate Drive STE 130",
					"addressLocality": "Raleigh",
					"addressRegion": "NC",
					"postalCode": "27617",
					"addressCountry": "US"
				},
				"telephone": "+1-919-351-6885",
				"email": "office@smgives.org"
			}
		})}></script>
	</Fragment>

	<main id="main-content">

		<!-- Hero -->
		<section class="relative w-full flex items-center justify-center" style="height: 60vh; background: #111; min-height: 400px;">
			<div class="absolute inset-0 bg-gradient-to-b from-black/30 to-black/50 z-10"></div>
			<div class="relative z-20 text-center px-5">
				<p class="font-sans font-bold text-off-white uppercase tracking-widest mb-4" style="font-size: 16px; letter-spacing: 3px;">Who We Are</p>
				<h1 class="type-hero text-off-white">About</h1>
			</div>
		</section>

		<!-- Mission (matching original about section style) -->
		<section style="background: rgba(158, 158, 158, 0.25); padding: 80px 20px;">
			<div class="mx-auto" style="max-width: 1300px;">
				<h2 class="type-section text-ink mb-8">We Are</h2>
				<div style="max-width: 900px;">
					<p class="font-body text-ink mb-6" style="font-size: 20px; line-height: 1.7;">
						SM Gives is a federally recognized 501 C 3 tax-exempt organization located in Raleigh, North Carolina.
						All gifts are tax deductible as allowed by law. We are the give back charity of Spirit Media Inc.
						All operational costs are underwritten by Spirit Media Inc.
					</p>
					<p class="font-body text-ink mb-6" style="font-size: 20px; line-height: 1.7; font-weight: 600;">
						100% of every gift impacts high need populations by empowering people to serve
						and by sharing life giving resources.
					</p>
				</div>
			</div>
		</section>

		<!-- Two-column: Empower -->
		<section class="flex flex-col md:flex-row w-full">
			<div class="w-full md:w-1/2 flex items-center justify-center text-center" style="background: #000; padding: 80px 40px; min-height: 400px;">
				<div style="max-width: 500px;">
					<h2 class="type-section text-off-white mb-6">Empower People to Serve</h2>
					<p class="font-body text-off-white/80" style="font-size: 20px; line-height: 1.7;">
						We believe being present is one of our greatest gifts. We empower people to go, serve,
						and make a lasting impact in high need populations by being present.
					</p>
				</div>
			</div>
			<div
				class="w-full md:w-1/2 bg-cover bg-center"
				style="background-image: url('https://cdn.sanity.io/images/6iqqd83h/production/f7fe7077084ce1b73be3aa927a5d8042276aec16-1024x535.jpg'); min-height: 400px;"
				role="img"
				aria-label="Church fellowship"
			></div>
		</section>

		<!-- Two-column: Sharing -->
		<section class="flex flex-col md:flex-row w-full">
			<div class="w-full md:w-1/2 flex items-center justify-center text-center" style="background: #c2000e; padding: 80px 40px; min-height: 400px;">
				<div style="max-width: 500px;">
					<h2 class="type-section text-off-white mb-6">Sharing Life Giving Resources</h2>
					<p class="font-body text-off-white/80" style="font-size: 20px; line-height: 1.7;">
						We empower generous donors to share life giving resources with high need populations.
					</p>
				</div>
			</div>
			<div
				class="w-full md:w-1/2 bg-cover bg-center"
				style="background-image: url('https://cdn.sanity.io/images/6iqqd83h/production/b7f12363c0b97b2aafa33230c68e66b7b6f15f59-600x378.webp'); min-height: 400px;"
				role="img"
				aria-label="Volunteers"
			></div>
		</section>

		<!-- Where we serve -->
		<section style="background: #e6e7e8; padding: 80px 20px;">
			<div class="mx-auto text-center" style="max-width: 1300px;">
				<h2 class="type-section text-ink mb-10">Where We Serve</h2>
				<div class="flex flex-wrap justify-center gap-0">
					{['India', 'Myanmar', 'Nepal', 'Nigeria', 'Prague', 'Uganda'].map((country) => (
						<div class="text-center p-8" style="border-top: 2px solid #616161; min-width: 200px; flex: 1;">
							<p class="font-sans font-bold text-ink uppercase" style="font-size: 28px; letter-spacing: 2px;">{country}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Programs -->
		<section style="background: #000; padding: 80px 20px;">
			<div class="mx-auto text-center" style="max-width: 1300px;">
				<h2 class="type-section text-off-white mb-12">Our Programs</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-0">
					{[
						{ title: 'Sending Volunteers', text: 'Supporting volunteers serving in India, Myanmar, Nepal, Nigeria, Prague and Uganda. 100% of every dollar goes directly to sending volunteers.', link: '/#programs' },
						{ title: 'Prayer Room', text: 'Establishing the first International House of Prayer for all Nations in Raleigh-Durham-Chapel Hill, NC.', link: '/#programs' },
						{ title: 'Gift of Courage', text: 'Sharing courage with families fighting cancer. Empowering them with victory over cancer.', link: '/#programs' },
						{ title: 'Deaf Biblical Ministries', text: 'Sponsoring 13 deaf students in Nagaland, India. Education, care, and dignity for $25/month.', link: '/deaf-biblical-ministries' },
					].map((card) => (
						<a href={card.link} class="block p-10 text-center hover:bg-white/5 transition-colors" style="border-top: 2px solid #616161;">
							<h3 class="font-sans font-bold text-off-white uppercase mb-4" style="font-size: 28px; letter-spacing: 2px;">{card.title}</h3>
							<p class="font-body text-off-white/70 mx-auto" style="font-size: 18px; line-height: 1.6; max-width: 400px;">{card.text}</p>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section style="background: #c2000e; padding: 80px 20px;">
			<div class="mx-auto text-center" style="max-width: 800px;">
				<h2 class="type-section text-off-white mb-6">Partner With Us</h2>
				<p class="font-body text-off-white/80 mb-10" style="font-size: 20px; line-height: 1.7;">
					Every gift makes a difference. Spirit Media Inc. covers all operational costs so 100% of your gift
					goes directly to the people and programs you support.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="/give" class="btn-primary" style="background: #fff; color: #c2000e;">Give Now</a>
					<a href="mailto:office@smgives.org" class="btn-primary" style="background: transparent; border: 2px solid #fff; color: #fff;">Contact Us</a>
				</div>
			</div>
		</section>

	</main>
</Layout>
