---
import Layout from '../layouts/Layout.astro';

const programs = [
	{
		title: 'Sending Volunteers',
		description: '100% of every dollar given supports sending volunteers to the nations. Currently, we are sending volunteers to India, Myanmar, Nepal, Nigeria, Prague and Uganda. With your support we can send more.',
		link: 'https://givebutter.com/SendingFund',
		image: 'https://cdn.sanity.io/images/6iqqd83h/production/78fe83d44fd9be78de44bbbed296dac13a695933-1024x341.jpg',
	},
	{
		title: 'Prayer Room',
		description: 'Join generous partners in establishing the first ever International House of Prayer for all Nations in the Raleigh, Durham, Chapel Hill area of North Carolina.',
		link: 'https://givebutter.com/prayrdu',
		image: 'https://cdn.sanity.io/images/6iqqd83h/production/ffa94afb91cb624dc6ea68320f315cde2ba03160-1024x683.jpg',
	},
	{
		title: 'Kevin White International',
		description: "Join generous partners in underwriting the cost of life giving resources and extending the reach of God's ministry through Kevin around the world. Thank you!",
		link: 'https://givebutter.com/KWI',
		image: 'https://cdn.sanity.io/images/6iqqd83h/production/59006c204e29c67aa4138deb445138c8ea80d160-683x1024.jpg',
	},
	{
		title: 'Gift of Courage',
		description: "Join generous partners in sharing courage with families fighting cancer. Together, let's empower them with victory over cancer.",
		link: 'https://givebutter.com/givecourage',
		image: 'https://cdn.sanity.io/images/6iqqd83h/production/63852620e1f766ad133c39e2965ffe99e454f6c7-1024x576.jpg',
	},
	{
		title: 'Deaf Biblical Ministries',
		description: "Join generous partners in sponsoring 13 deaf students at Deaf Biblical Ministries in Nagaland, India. Together, let's empower them with education, care, and dignity.",
		link: 'https://givebutter.com/DeafBiblicalMinistry',
		image: 'https://cdn.sanity.io/images/6iqqd83h/production/41833ddcfa23fe2c0d38a882c98efd8f9b2a0a8e-1024x691.jpg',
	},
];

const values = [
	{ word: 'Hope', image: 'https://cdn.sanity.io/images/6iqqd83h/production/78fe83d44fd9be78de44bbbed296dac13a695933-1024x341.jpg' },
	{ word: 'Love', image: 'https://cdn.sanity.io/images/6iqqd83h/production/66503dc54fb420f6bcad0e052cccc93dfe4f5b0b-791x1024.jpg' },
	{ word: 'Courage', image: 'https://cdn.sanity.io/images/6iqqd83h/production/63852620e1f766ad133c39e2965ffe99e454f6c7-1024x576.jpg' },
	{ word: 'Compassion', image: 'https://cdn.sanity.io/images/6iqqd83h/production/ffa94afb91cb624dc6ea68320f315cde2ba03160-1024x683.jpg' },
	{ word: 'Comfort', image: 'https://cdn.sanity.io/images/6iqqd83h/production/59006c204e29c67aa4138deb445138c8ea80d160-683x1024.jpg' },
	{ word: 'Salvation', image: 'https://cdn.sanity.io/images/6iqqd83h/production/49dacef292712f9564a495490e30df54d8c3898b-540x360.jpg' },
	{ word: 'Healing', image: 'https://cdn.sanity.io/images/6iqqd83h/production/76454dde4a7cb859f1031255a69476395c8cba61-1000x528.jpg' },
	{ word: 'Deliverance', image: 'https://cdn.sanity.io/images/6iqqd83h/production/e729451f90da47d2ceb96270c6f064ba11c4cb80-275x183.jpg' },
	{ word: 'Restoration', image: 'https://cdn.sanity.io/images/6iqqd83h/production/41833ddcfa23fe2c0d38a882c98efd8f9b2a0a8e-1024x691.jpg' },
	{ word: 'Wisdom', image: 'https://cdn.sanity.io/images/6iqqd83h/production/57c9b89f458b75ba105326abf59b5169ff40d516-1024x576.jpg' },
	{ word: 'Leadership', image: 'https://cdn.sanity.io/images/6iqqd83h/production/c0ca374c626574e74c57a410d32157594b072d64-800x533.jpg' },
	{ word: 'Faith', image: 'https://cdn.sanity.io/images/6iqqd83h/production/839926c34f56789f0e1aab8eb80e9125b6c77008-800x534.webp' },
];

const countries = [
	'Afghanistan','Albania','Algeria','Andorra','Angola','Antigua and Barbuda','Argentina','Armenia','Australia','Austria',
	'Azerbaijan','Bahamas','Bahrain','Bangladesh','Barbados','Belarus','Belgium','Belize','Benin','Bhutan',
	'Bolivia','Bosnia and Herzegovina','Botswana','Brazil','Brunei','Bulgaria','Burkina Faso','Burundi','Cabo Verde','Cambodia',
	'Cameroon','Canada','Central African Republic','Chad','Chile','China','Colombia','Comoros','Congo','Costa Rica',
	'Croatia','Cuba','Cyprus','Czech Republic','Denmark','Djibouti','Dominica','Dominican Republic','Ecuador','Egypt',
	'El Salvador','Equatorial Guinea','Eritrea','Estonia','Eswatini','Ethiopia','Fiji','Finland','France','Gabon',
	'Gambia','Georgia','Germany','Ghana','Greece','Grenada','Guatemala','Guinea','Guinea-Bissau','Guyana',
	'Haiti','Honduras','Hungary','Iceland','India','Indonesia','Iran','Iraq','Ireland','Israel',
	'Italy','Jamaica','Japan','Jordan','Kazakhstan','Kenya','Kiribati','Kuwait','Kyrgyzstan','Laos',
	'Latvia','Lebanon','Lesotho','Liberia','Libya','Liechtenstein','Lithuania','Luxembourg','Madagascar','Malawi',
	'Malaysia','Maldives','Mali','Malta','Marshall Islands','Mauritania','Mauritius','Mexico','Micronesia','Moldova',
	'Monaco','Mongolia','Montenegro','Morocco','Mozambique','Myanmar','Namibia','Nauru','Nepal','Netherlands',
	'New Zealand','Nicaragua','Niger','Nigeria','North Korea','North Macedonia','Norway','Oman','Pakistan','Palau',
	'Palestine','Panama','Papua New Guinea','Paraguay','Peru','Philippines','Poland','Portugal','Qatar','Romania',
	'Russia','Rwanda','Saint Kitts and Nevis','Saint Lucia','Saint Vincent and the Grenadines','Samoa','San Marino',
	'Sao Tome and Principe','Saudi Arabia','Senegal','Serbia','Seychelles','Sierra Leone','Singapore','Slovakia','Slovenia',
	'Solomon Islands','Somalia','South Africa','South Korea','South Sudan','Spain','Sri Lanka','Sudan','Suriname','Sweden',
	'Switzerland','Syria','Taiwan','Tajikistan','Tanzania','Thailand','Timor-Leste','Togo','Tonga','Trinidad and Tobago',
	'Tunisia','Turkey','Turkmenistan','Tuvalu','Uganda','Ukraine','United Arab Emirates','United Kingdom','United States',
	'Uruguay','Uzbekistan','Vanuatu','Vatican City','Venezuela','Vietnam','Yemen','Zambia','Zimbabwe',
];
---

<Layout
	title="SM Gives — Impact Nations"
	description="SM Gives is a 501(c)(3) nonprofit empowering people to serve and sharing life giving resources with high need populations around the world."
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "NonprofitOrganization",
			"name": "Spirit Media Charities",
			"alternateName": "SM Gives",
			"url": "https://smgives.org",
			"description": "501(c)(3) tax-exempt organization empowering people to serve and sharing life giving resources with high need populations.",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "8045 Arco Corporate Drive STE 130",
				"addressLocality": "Raleigh",
				"addressRegion": "NC",
				"postalCode": "27617",
				"addressCountry": "US"
			},
			"telephone": "+1-919-351-6885",
			"email": "office@smgives.org",
			"parentOrganization": { "@type": "Organization", "name": "Spirit Media Inc." }
		})}></script>
	</Fragment>

	<main id="main-content">

		<!-- ═══ HERO — Impact Nations (100vh, dark overlay, animated country names) ═══ -->
		<section class="relative w-full flex items-center justify-center overflow-hidden" style="height: 100vh; margin-top: -70px; background: #111;">
			<div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/10 to-black/40 z-10"></div>
			<div class="relative z-20 text-center px-5">
				<p class="font-sans font-bold text-off-white uppercase tracking-widest mb-6" style="font-size: 20px; letter-spacing: 3px;">Impact Nations</p>
				<h1 id="hero-country" class="type-hero text-off-white"></h1>
			</div>
		</section>

		<!-- ═══ VALUES CAROUSEL (horizontal scroll, dark overlay on images) ═══ -->
		<section class="w-full overflow-hidden" style="background: #111;">
			<div class="flex overflow-x-auto scrollbar-hide snap-x snap-mandatory" id="values-scroll">
				{values.map((v) => (
					<div
						class="snap-start shrink-0 relative flex items-center justify-center"
						style="width: 200px; height: 150px;"
					>
						<img src={v.image} alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
						<div class="absolute inset-0" style="background: rgba(33, 33, 33, 0.6);"></div>
						<span class="relative z-10 font-sans font-bold text-white uppercase text-center" style="font-size: 22px; letter-spacing: 2px;">{v.word}</span>
					</div>
				))}
			</div>
		</section>

		<!-- ═══ GIVING PROGRAMS (full-width hero cards on red background) ═══ -->
		<section style="background: #c2000e;">
			<div class="flex flex-wrap">
				{programs.map((program) => (
					<a
						href={program.link}
						target="_blank"
						rel="noopener noreferrer"
						class="relative block w-full md:w-1/2 overflow-hidden group"
						style="min-height: 450px;"
					>
						<img
							src={program.image}
							alt={program.title}
							class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
							loading="lazy"
						/>
						<div class="absolute inset-0" style="background: rgba(33, 33, 33, 0.6);"></div>
						<div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-10 py-16" style="min-height: 450px;">
							<h3 class="type-card-heading text-white mb-6">{program.title}</h3>
							<p class="font-body text-white/90 max-w-lg mb-8" style="font-size: 18px; line-height: 1.6;">{program.description}</p>
							<span class="btn-primary">Give Now</span>
						</div>
					</a>
				))}
				<!-- Last card spans full width on desktop -->
			</div>
		</section>

		<!-- ═══ GIVE NOW BANNER (pink background) ═══ -->
		<section id="give-now" style="background: #ffc0cb; padding: 80px 20px;">
			<div class="mx-auto text-center" style="max-width: 800px;">
				<h2 class="type-section text-ink mb-8">Give Now</h2>
				<p class="font-body text-ink mb-10" style="font-size: 20px; line-height: 1.6;">
					100% of your gift goes to the project being funded. Spirit Media Inc. covers all the management cost
					for Spirit Media Charities so that 100% of every gift goes to the project being funded.
					On behalf of everyone at Spirit Media, thank you for your generous support!
				</p>

				<div class="flex flex-col md:flex-row gap-6 justify-center items-start text-left mb-10">
					<div class="flex-1 text-center">
						<p class="font-sans font-bold text-ink uppercase mb-2" style="font-size: 16px; letter-spacing: 2px;">Text to Give</p>
						<p class="font-body text-ink" style="font-size: 18px;">Text <strong>"Give"</strong> to<br /><strong style="font-size: 24px;">(833) 255-2177</strong></p>
					</div>
					<div class="flex-1 text-center">
						<p class="font-sans font-bold text-ink uppercase mb-2" style="font-size: 16px; letter-spacing: 2px;">ACH Transfer</p>
						<p class="font-body text-ink" style="font-size: 16px;">
							Spirit Media Charities<br />
							Coastal Federal Credit Union<br />
							Routing: 253175494<br />
							Account: 10010001599596
						</p>
					</div>
					<div class="flex-1 text-center">
						<p class="font-sans font-bold text-ink uppercase mb-2" style="font-size: 16px; letter-spacing: 2px;">Mail a Check</p>
						<p class="font-body text-ink" style="font-size: 16px;">
							Spirit Media Charities<br />
							8045 Arco Corporate Drive<br />
							STE 130<br />
							Raleigh, NC 27617
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══ ABOUT SECTION (light gray bg) ═══ -->
		<section id="about" style="background: rgba(158, 158, 158, 0.25); padding: 80px 20px;">
			<div class="mx-auto" style="max-width: 1300px;">
				<div class="mb-6">
					<span class="inline-block btn-primary" style="padding: 10px 20px; font-size: 14px; pointer-events: none;">About</span>
				</div>
				<h2 class="type-section text-ink mb-8">We Are</h2>
				<div style="max-width: 900px;">
					<p class="font-body text-ink mb-6" style="font-size: 20px; line-height: 1.7;">
						SM Gives is a federally recognized 501 C 3 tax-exempt organization located in Raleigh, North Carolina.
						All gifts are tax deductible as allowed by law. We are the give back charity of Spirit Media Inc.
						All operational costs are underwritten by Spirit Media Inc. 100% of every gift impacts high need
						populations by empowering people to serve and by sharing life giving resources.
					</p>
					<p class="font-body text-ink" style="font-size: 20px; line-height: 1.7;">
						Contact us: <a href="mailto:info@smgives.org" class="text-red underline hover:text-red-dark">info@smgives.org</a>
					</p>
				</div>
			</div>
		</section>

		<!-- ═══ TWO-COLUMN: Empower People to Serve (black + image) ═══ -->
		<section class="flex flex-col md:flex-row w-full">
			<div class="w-full md:w-1/2 flex items-center justify-center text-center" style="background: #000; padding: 80px 40px; min-height: 450px;">
				<div style="max-width: 500px;">
					<h2 class="type-section text-off-white mb-6">Empower People to Serve</h2>
					<p class="font-body text-off-white/80" style="font-size: 20px; line-height: 1.7;">
						We believe being present is one of our greatest gifts. We empower people to go, serve,
						and make a lasting impact in high need populations by being present.
					</p>
				</div>
			</div>
			<div
				class="w-full md:w-1/2 bg-cover bg-center"
				style="background-image: url('https://cdn.sanity.io/images/6iqqd83h/production/f7fe7077084ce1b73be3aa927a5d8042276aec16-1024x535.jpg'); min-height: 450px;"
				role="img"
				aria-label="Church fellowship"
			></div>
		</section>

		<!-- ═══ TWO-COLUMN: Sharing Life Giving Resources (red + image) ═══ -->
		<section class="flex flex-col md:flex-row w-full">
			<div class="w-full md:w-1/2 flex items-center justify-center text-center" style="background: #c2000e; padding: 80px 40px; min-height: 450px;">
				<div style="max-width: 500px;">
					<h2 class="type-section text-off-white mb-6">Sharing Life Giving Resources</h2>
					<p class="font-body text-off-white/80" style="font-size: 20px; line-height: 1.7;">
						We empower generous donors to share life giving resources with high need populations.
					</p>
				</div>
			</div>
			<div
				class="w-full md:w-1/2 bg-cover bg-center"
				style="background-image: url('https://cdn.sanity.io/images/6iqqd83h/production/b7f12363c0b97b2aafa33230c68e66b7b6f15f59-600x378.webp'); min-height: 450px;"
				role="img"
				aria-label="Volunteers working at humanitarian aid center"
			></div>
		</section>

		<!-- ═══ PROGRAM DETAIL CARDS (gray bg, border-top) ═══ -->
		<section style="background: #e6e7e8; padding: 80px 20px;">
			<div class="mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0" style="max-width: 1300px;">
				{[
					{ title: 'Send More Volunteers', text: 'Support sending volunteers to India, Myanmar, Nepal, Nigeria, Prague and Uganda. 100% of every dollar given goes directly to sending volunteers.' },
					{ title: 'Pray With Us', text: 'Join generous partners establishing the first International House of Prayer for all Nations in the Raleigh-Durham-Chapel Hill area of North Carolina.' },
					{ title: 'Kevin White International', text: "Underwrite the cost of life giving resources and extending God's ministry through Kevin around the world." },
					{ title: 'Gift of Courage', text: 'Share courage with families fighting cancer. Together, empower them with victory over cancer.' },
					{ title: 'Deaf Biblical Ministries', text: 'Sponsor 13 deaf students at Deaf Biblical Ministries in Nagaland, India. Education, care, and dignity for just $25/month.' },
					{ title: 'Light Hospital', text: 'Support the construction of a comprehensive healthcare facility serving marginalized communities. Building the Kingdom of God through healing.' },
				].map((card) => (
					<div class="p-10 text-center" style="border-top: 2px solid #616161;">
						<h3 class="type-section text-ink mb-6" style="font-size: 28px;">{card.title}</h3>
						<p class="font-body text-ink/80" style="font-size: 18px; line-height: 1.6; max-width: 400px; margin: 0 auto;">
							{card.text}
						</p>
					</div>
				))}
			</div>
		</section>

	</main>
</Layout>

<script define:vars={{ countries }}>
	const el = document.getElementById('hero-country');
	if (el) {
		let i = 0;
		el.textContent = countries[0];
		setInterval(() => {
			i = (i + 1) % countries.length;
			el.style.opacity = '0';
			setTimeout(() => {
				el.textContent = countries[i];
				el.style.opacity = '1';
			}, 400);
		}, 2500);
		el.style.transition = 'opacity 0.4s ease';
	}

	// Auto-scroll values carousel
	const scroll = document.getElementById('values-scroll');
	if (scroll) {
		let pos = 0;
		setInterval(() => {
			pos += 1;
			if (pos >= scroll.scrollWidth - scroll.clientWidth) pos = 0;
			scroll.scrollLeft = pos;
		}, 30);
	}
</script>
