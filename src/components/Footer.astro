---
const year = new Date().getFullYear();
---

<footer style="background: #000; padding: 60px 20px;">
	<div class="mx-auto text-center" style="max-width: 1300px;">
		<!-- Logo -->
		<p class="font-sans font-bold text-off-white uppercase tracking-wider mb-6" style="font-size: 22px;">Spirit Media Charities</p>

		<!-- Address -->
		<address class="not-italic text-off-white/70 mb-6" style="font-size: 16px; line-height: 1.8;">
			8045 Arco Corporate Drive STE 130<br />
			Raleigh, NC 27617<br />
			<a href="tel:+19193516885" class="hover:text-white transition-colors">(919) 351-6885</a>
		</address>

		<!-- Contact -->
		<p class="mb-6">
			<a href="mailto:office@smgives.org" class="text-off-white/70 hover:text-white transition-colors" style="font-size: 16px;">
				Contact Us: office@smgives.org
			</a>
		</p>

		<!-- Give Now button -->
		<div class="mb-8">
			<a href="/#give-now" class="btn-primary">Give Now</a>
		</div>

		<!-- Copyright -->
		<div class="pt-6" style="border-top: 1px solid rgba(255,255,255,0.1);">
			<p class="text-off-white/40" style="font-size: 14px;">
				&copy; {year} Spirit Media Charities, All rights reserved.
			</p>
			<p class="text-off-white/30 mt-1" style="font-size: 13px;">
				Design by <a href="https://spiritmediapublishing.com" class="hover:text-white transition-colors">Spirit Media</a>
			</p>
		</div>
	</div>
</footer>
