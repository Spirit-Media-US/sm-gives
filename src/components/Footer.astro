---
const year = new Date().getFullYear();
---

<footer style="background: #000; padding: 40px;">
	<div class="mx-auto" style="max-width: 1440px;">
		<!-- 3-column row -->
		<div class="flex flex-col md:flex-row items-center md:items-start gap-8">
			<!-- Left: Logo + address + contact -->
			<div class="flex-1 text-center md:text-left">
				<a href="/">
					<img src="https://cdn.sanity.io/images/6iqqd83h/production/39ebed6f22528f218129e9d3b4437e99fde707c0-1024x239.png?w=400&fm=webp&q=85" alt="SM Gives" width="214" height="50" loading="lazy" decoding="async" style="height: 50px; width: auto;" class="mx-auto md:mx-0" />
				</a>
				<address class="not-italic text-off-white mt-5" style="font-family: var(--font-accent); font-size: 20px; line-height: 1.8;">
					8045 Arco Corporate Drive STE 130<br />
					Raleigh, NC 27617<br />
					<a href="tel:+19193516885" class="hover:text-white transition-colors">(919) 351-6885</a>
				</address>
				<h3 class="mt-4">
					<a href="mailto:office@smgives.org" class="font-accent text-off-white underline hover:text-white transition-colors" style="font-size: 20px; font-weight: 400;">
						Contact Us
					</a>
				</h3>
			</div>

			<!-- Center: Give Now button -->
			<div class="flex-1 flex items-center justify-center" style="margin-top: 80px;">
				<a href="/give" class="btn-primary">Give Now</a>
			</div>

			<!-- Right: Office image -->
			<div class="hidden md:block flex-1">
				<div
					class="w-full bg-cover bg-center rounded"
					style="background-image: url('https://cdn.sanity.io/images/6iqqd83h/production/9fe92ee3f956c69ee9db71fae4d60efd67d4b003-1024x560.webp?w=800&fm=webp&q=80'); height: 200px;"
					role="img"
					aria-label="Office"
				></div>
			</div>
		</div>

		<!-- Copyright row -->
		<div class="text-center mt-6" style="padding-top: 10px;">
			<p style="color: rgba(245,245,245,0.49); font-size: 14px;">
				&copy; {year} Spirit Media Charities, All rights reserved.
			</p>
			<p style="color: rgba(245,245,245,0.6); font-size: 13px; margin-top: 4px;">
				Design by <a href="https://spiritmediapublishing.com" class="hover:text-white transition-colors" style="color: rgba(245,245,245,0.6);">Spirit Media</a>
			</p>
		</div>
	</div>
</footer>
