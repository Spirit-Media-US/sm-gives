---
const year = new Date().getFullYear();
---

<footer class="bg-ink text-stone-400 px-6 py-12 lg:px-8">
	<div class="mx-auto max-w-7xl">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			<!-- Brand -->
			<div>
				<p class="font-heading font-bold text-white text-xl mb-3">SM Gives</p>
				<p class="text-sm leading-relaxed">
					Spirit Media Charities is a federally recognized 501(c)(3) tax-exempt organization.
					100% of every gift impacts high need populations.
				</p>
			</div>

			<!-- Contact -->
			<div>
				<p class="font-accent font-semibold text-white text-sm uppercase tracking-wider mb-3">Contact</p>
				<address class="not-italic text-sm leading-relaxed space-y-1">
					<p>8045 Arco Corporate Drive STE 130</p>
					<p>Raleigh, NC 27617</p>
					<p><a href="tel:+19193516885" class="hover:text-white transition-colors">(919) 351-6885</a></p>
					<p><a href="mailto:office@smgives.org" class="hover:text-white transition-colors">office@smgives.org</a></p>
				</address>
			</div>

			<!-- Quick Links -->
			<div>
				<p class="font-accent font-semibold text-white text-sm uppercase tracking-wider mb-3">Quick Links</p>
				<nav class="flex flex-col gap-2 text-sm">
					<a href="/#about" class="hover:text-white transition-colors">About</a>
					<a href="/#programs" class="hover:text-white transition-colors">Programs</a>
					<a href="/blog" class="hover:text-white transition-colors">Blog</a>
					<a href="/deaf-biblical-ministries" class="hover:text-white transition-colors">Deaf Biblical Ministries</a>
					<a href="/#give-now" class="hover:text-white transition-colors">Give Now</a>
				</nav>
			</div>
		</div>

		<div class="mt-10 pt-6 border-t border-white/10 text-center text-xs text-stone-500">
			<p>&copy; {year} Spirit Media Charities. All rights reserved.</p>
			<p class="mt-1">Design by <a href="https://spiritmediapublishing.com" class="hover:text-white transition-colors">Spirit Media</a></p>
		</div>
	</div>
</footer>
