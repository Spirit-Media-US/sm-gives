---
const currentPath = Astro.url.pathname;
const links = [
	{ label: 'About', href: '/#about' },
	{ label: 'Give', href: '/give' },
	{ label: 'Blogs', href: '/blog' },
];
---

<header class="fixed top-0 left-0 right-0 z-50" style="background: rgba(10, 10, 10, 0.28); backdrop-filter: blur(4px);">
	<div class="mx-auto flex items-center justify-between px-5 py-5" style="max-width: 1300px;">
		<!-- Logo -->
		<a href="/" class="flex items-center">
			<span class="font-sans font-bold text-off-white text-lg uppercase tracking-wider">Spirit Media Charities</span>
		</a>

		<!-- Desktop nav -->
		<nav class="hidden md:flex items-center" style="gap: 30px;">
			{links.map(link => (
				<a
					href={link.href}
					class="font-sans font-bold text-off-white uppercase text-sm tracking-wider hover:text-white transition-colors"
					style="font-size: 20px;"
				>
					{link.label}
				</a>
			))}
			<a href="/give" class="btn-primary" style="padding: 12px 24px; font-size: 14px;">Give Now</a>
		</nav>

		<!-- Mobile hamburger -->
		<button
			id="mobile-menu-btn"
			class="md:hidden text-off-white p-2"
			aria-label="Open menu"
			aria-expanded="false"
		>
			<svg id="hamburger-icon" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
			<svg id="close-icon" class="w-7 h-7 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>
	</div>

	<!-- Mobile menu -->
	<div id="mobile-menu" class="hidden md:hidden px-5 pb-6" style="background: rgba(10, 10, 10, 0.95);">
		<nav class="flex flex-col gap-5 pt-4">
			{links.map(link => (
				<a
					href={link.href}
					class="font-sans font-bold text-off-white uppercase text-base tracking-wider mobile-nav-link"
				>
					{link.label}
				</a>
			))}
			<a href="/give" class="btn-primary text-center mt-2">Give Now</a>
		</nav>
	</div>
</header>

<script>
const btn = document.getElementById('mobile-menu-btn');
const menu = document.getElementById('mobile-menu');
const hamburger = document.getElementById('hamburger-icon');
const closeIcon = document.getElementById('close-icon');

btn?.addEventListener('click', () => {
	const open = menu?.classList.toggle('hidden') === false;
	hamburger?.classList.toggle('hidden', open);
	closeIcon?.classList.toggle('hidden', !open);
	btn?.setAttribute('aria-expanded', String(open));
});

document.querySelectorAll('.mobile-nav-link').forEach(link => {
	link.addEventListener('click', () => {
		menu?.classList.add('hidden');
		hamburger?.classList.remove('hidden');
		closeIcon?.classList.add('hidden');
		btn?.setAttribute('aria-expanded', 'false');
	});
});
</script>
