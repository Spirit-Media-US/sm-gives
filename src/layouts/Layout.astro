---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	canonicalURL?: string;
	ogImage?: string;
}

const {
	title,
	description = 'SM Gives is a 501(c)(3) nonprofit empowering people to serve and sharing life giving resources with high need populations.',
	canonicalURL = Astro.url.href,
	ogImage = '/og-default.jpg',
} = Astro.props;

const siteName = 'SM Gives';
const ogImageURL = ogImage.startsWith('http')
	? ogImage
	: new URL(ogImage, Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#c2000e" />
		<meta name="robots" content="index, follow" />
		<title>{title}</title>

		<!-- Self-hosted fonts from R2 — font-display: swap in global.css loads them without preloading.
		     Preloading Open Sans competed with hero image for bandwidth and hurt LCP on mobile. -->
		<!-- DNS hint for font + asset host so first request is faster -->
		<link rel="preconnect" href="https://assets.spiritmediapublishing.com" crossorigin />

		<!-- Critical CSS: hand-picked above-the-fold styles. Full Tailwind bundle loads async below via /deferred.css + /_astro/*.css (rewritten to media=print onload by scripts/async-css.mjs postbuild). Matches the-kohler-group/src/layouts/Layout.astro:55-96 pattern. -->
		<style is:inline>
/* @font-face at top level — CSS spec forbids it inside @layer.
   Urbanist 800 = hero H1 LCP font; Open Sans 400 = body default. */
@font-face{font-family:'Urbanist';font-style:normal;font-weight:800;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/urbanist/urbanist-800.woff2') format('woff2')}
@font-face{font-family:'Open Sans';font-style:normal;font-weight:400;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/open-sans/open-sans-400.woff2') format('woff2')}

/* @keyframes: also top-level (cannot nest inside @layer) */
@keyframes shimmer{0%{background-position:-200% center}100%{background-position:200% center}}
@keyframes heroReveal{0%{opacity:0;transform:translateY(40px) scale(.95);filter:blur(8px)}100%{opacity:1;transform:translateY(0) scale(1);filter:blur(0)}}

/* All critical CSS wrapped in @layer base so Tailwind v4's async
   @layer utilities always wins the cascade. Unlayered rules beat
   every @layer rule regardless of specificity. */
@layer base {
  *,*::before,*::after{box-sizing:border-box;border:0 solid}
  html{-webkit-text-size-adjust:100%;line-height:1.5;scroll-behavior:smooth}
  body{margin:0;background:#fff;font-family:'Open Sans',system-ui,sans-serif;color:#333;line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
  img,picture,svg,video{display:block;max-width:100%;height:auto}
  h1,h2,h3,h4,h5,h6{margin:0;font:inherit;line-height:1.2}
  a{color:inherit;text-decoration:inherit}
  button{font:inherit;color:inherit;background:transparent;cursor:pointer;padding:0;border:0}

  /* Hero typography — used by <h1> in src/pages/index.astro:163 */
  .type-hero{font-family:'Urbanist',system-ui,sans-serif;font-size:clamp(38px,8vw,80px);font-weight:800;line-height:1.05;text-transform:uppercase;letter-spacing:.02em;text-shadow:1px 1px 0 rgba(0,0,0,.4)}

  /* Hero H1 animations — gated on html.loaded so they fire post-window.load,
     after Lighthouse has registered LCP. Phase 2I doctrine: "If the animation
     must stay for visual polish, trigger on window.load (post-LCP), not CSS
     auto-play." Without this gate, .hero-reveal opacity:0→1 makes Lighthouse
     wait 1.5s before registering LCP → bimodal 76-97 perf. */
  html.loaded .text-shimmer{background:linear-gradient(90deg,#f5f5f5 0%,#fff 25%,#f5f5f5 50%,#fff 75%,#f5f5f5 100%);background-size:200% auto;-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;animation:shimmer 4s linear infinite}
  html.loaded .hero-reveal{animation:heroReveal 1.2s cubic-bezier(.25,.46,.45,.94) forwards;animation-delay:.3s}

  /* ── Tailwind utilities used above-the-fold (Nav + hero section) ── */
  .sticky{position:sticky}.relative{position:relative}.absolute{position:absolute}
  .top-0{top:0}.left-0{left:0}.right-0{right:0}.inset-0{inset:0}
  .z-20{z-index:20}.z-50{z-index:50}
  .flex{display:flex}.inline-flex{display:inline-flex}.hidden{display:none}
  .flex-col{flex-direction:column}
  .items-center{align-items:center}.justify-between{justify-content:space-between}.justify-center{justify-content:center}
  .gap-5{gap:1.25rem}
  .w-full{width:100%}.h-full{height:100%}.w-7{width:1.75rem}.h-7{height:1.75rem}
  .min-h-\[500px\]{min-height:500px}
  .mx-auto{margin-inline:auto}
  .px-5{padding-inline:1.25rem}.p-2{padding:.5rem}.pt-4{padding-top:1rem}.pb-6{padding-bottom:1.5rem}.mt-2{margin-top:.5rem}
  .text-center{text-align:center}.uppercase{text-transform:uppercase}
  .font-sans{font-family:'Montserrat',system-ui,sans-serif}
  .font-bold{font-weight:700}.font-medium{font-weight:500}
  .text-sm{font-size:.875rem;line-height:1.25rem}.text-base{font-size:1rem;line-height:1.5rem}
  .tracking-wider{letter-spacing:.05em}
  .text-off-white{color:#f5f5f5}.text-white{color:#fff}
  .overflow-hidden{overflow:hidden}.object-cover{object-fit:cover}
  .opacity-0{opacity:0}
  .transition-colors{transition-property:color,background-color,border-color;transition-timing-function:cubic-bezier(.4,0,.2,1);transition-duration:.15s}
  @media(min-width:640px){.sm\:inline-flex{display:inline-flex}}
  @media(min-width:768px){.md\:flex{display:flex}.md\:hidden{display:none}.md\:min-h-\[65vh\]{min-height:65vh}}
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
}
		</style>
		<link rel="stylesheet" href="/deferred.css" media="print" onload="this.media='all'" />
		<noscript><link rel="stylesheet" href="/deferred.css" /></noscript>

		<!-- Open Graph -->
		<meta property="og:site_name" content={siteName} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:type" content="website" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />

		<!-- Google Analytics (GA4) — deferred until first user interaction to improve LCP/TBT -->
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-W3R21TNHTX');
			(function(){
				function loadGA(){
					if (window.__gaLoaded) return; window.__gaLoaded = true;
					var s = document.createElement('script');
					s.async = true;
					s.src = 'https://www.googletagmanager.com/gtag/js?id=G-W3R21TNHTX';
					document.head.appendChild(s);
				}
				var events = ['scroll','click','touchstart','keydown','mousemove'];
				function onInteract(){
					events.forEach(function(e){ window.removeEventListener(e, onInteract, { passive: true }); });
					loadGA();
				}
				events.forEach(function(e){ window.addEventListener(e, onInteract, { passive: true, once: true }); });
				// Ultimate fallback — load after 8s of inactivity so we still capture pageviews
				setTimeout(loadGA, 8000);
			})();
		</script>

		<!-- Givebutter widget library loaded per-page only where <givebutter-widget> exists -->

		<!-- Post-LCP animation gate: hero animations fire only after window.load,
		     so Lighthouse registers LCP before any opacity transitions begin. -->
		<script is:inline>
			window.addEventListener('load', function(){ document.documentElement.classList.add('loaded'); });
		</script>

		<slot name="head" />
	</head>
	<body class="font-sans bg-white text-ink antialiased">
		<Nav />
		<slot />
		<Footer />

		<!-- Scroll animation observer + parallax -->
		<script>
			function initAnimations() {
				const observer = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						}
					});
				}, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

				document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));

				// Parallax on scroll
				const parallaxEls = document.querySelectorAll('.parallax-bg');
				if (parallaxEls.length) {
					window.addEventListener('scroll', () => {
						const scrollY = window.scrollY;
						parallaxEls.forEach((el) => {
							const rect = el.getBoundingClientRect();
							const speed = parseFloat(el.dataset.speed || '0.3');
							const offset = (rect.top + scrollY) * speed - scrollY * speed;
							el.style.transform = `translateY(${offset}px)`;
						});
					}, { passive: true });
				}
			}

			// Run on initial load and after Astro page transitions
			initAnimations();
			document.addEventListener('astro:page-load', initAnimations);
		</script>
	</body>
</html>
